{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: Debug & Launch",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "serverReadyAction": {
                "pattern": "Local:.*http://localhost:([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "action": "debugWithChrome"
            }
        }
    ]
}